{
  "name": "tally",
  "version": "1.0.0",
  "private": true,
  "module": "module",
  "scripts": {
    "dev": "docker compose up -d && next dev --turbo ",
    "worker": "dotenv -e .env -- tsx src/lib/redis/redis-Worker.ts",
    "worker:prod": "node --import dotenv/config --import tsx src/lib/redis/redis-Worker.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "check-errors": "pnpm lint:fix && pnpm format && pnpm build",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:studio": "prisma studio",
    "test": "vitest",
    "test:unit": "vitest run --dir src/lib/auth/__tests__ --exclude **/*.int.test.ts",
    "pretest:int": "dotenv -e .env -- tsx src/lib/db/check-connection.ts",
    "test:int": "dotenv -e .env -- vitest run src/lib/auth/__tests__/service.int.test.ts",
    "down": "docker compose down"
  },
  "dependencies": {
    "@dnd-kit/react": "^0.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.38.0",
    "go-aura": "^1.0.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.14.0",
    "next": "16.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@swc/core": "^1.15.33",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.41",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.1",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.6",
    "vitest-mock-extended": "^3.1.1"
  }
}
