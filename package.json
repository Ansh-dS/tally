{
  "name": "tally",
  "version": "0.1.0",
  "private": true,
  "module": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "check-errors": "pnpm build && pnpm lint:fix && pnpm format",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:studio": "prisma studio",
    "test": "vitest",
    "test:unit": "vitest run --dir src/lib/auth/__tests__ --exclude **/*.int.test.ts",
    "pretest:int": "dotenv -e .env -- tsx src/lib/db/check-connection.ts",
    "test:int": "dotenv -e .env -- vitest run src/lib/auth/__tests__/service.int.test.ts"
  },
  "dependencies": {
    "@dnd-kit/react": "^0.4.0",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "components": "link:../uiLibrary/packages/ui",
    "dotenv": "^17.2.3",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.8.0",
    "next": "16.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.3.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@swc/core": "^1.15.8",
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "prettier": "^3.8.3",
    "prisma": "^7.2.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.0.17",
    "vitest-mock-extended": "^3.1.0"
  }
}
